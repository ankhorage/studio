{
  "name": "@ankhorage/studio-app",
  "main": "index.js",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare:root-package": "bun run --cwd ../.. build",
    "build": "bun run prepare:root-package && bun x tsc -p tsconfig.json",
    "type-check": "bun run prepare:root-package && bun x tsc -p tsconfig.json",
    "start": "bun run prepare:root-package && expo start",
    "web": "bun run prepare:root-package && expo start --web",
    "android": "bun run prepare:root-package && expo start --android",
    "ios": "bun run prepare:root-package && expo start --ios",
    "lint": "expo lint"
  },
  "dependencies": {
    "@ankhorage/studio": "workspace:*",
    "@expo/vector-icons": "^15.0.3",
    "babel-preset-expo": "^54.0.10",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.22",
    "expo-status-bar": "^3.0.9",
    "expo-updates": "~29.0.17",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "babel-plugin-module-resolver": "^5.0.2"
  }
}
