{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "tsBuildInfoFile": "tsconfig.tsbuildinfo"
  },
  "include": [
    "src/index.ts",
    "src/canvasDropZones.ts",
    "src/insertModalModel.ts",
    "src/localizationConfig.ts",
    "src/manifestNavigatorPreviewModel.ts",
    "src/manifestState.ts",
    "src/manifestSync.ts",
    "src/routeUtils.ts"
  ],
  "exclude": ["src/**/*.test.ts"]
}
